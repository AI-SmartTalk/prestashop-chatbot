# Apache 2.2
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
    <Files ~ "\.(png|jpg|gif|svg|ico)$">
        Order allow,deny
        Allow from all
    </Files>
</IfModule>

# Apache 2.4
<IfModule mod_authz_core.c>
    Require all denied
    <FilesMatch "\.(png|jpg|gif|svg|ico)$">
        Require all granted
    </FilesMatch>
</IfModule>
